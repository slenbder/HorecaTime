# HorecaTime Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file with real credentials!

# ─── Telegram Bot ────────────────────────────────────────────────────────────

# Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# ─── Role IDs ────────────────────────────────────────────────────────────────

# Single Telegram user ID with developer access (receives error alerts)
DEVELOPER_ID=123456789

# Comma-separated Telegram user IDs (no spaces)
SUPERADMIN_IDS=111111111,222222222
ADMIN_HALL_IDS=333333333,444444444
ADMIN_BAR_IDS=555555555
ADMIN_KITCHEN_IDS=666666666

# ─── Google Sheets ───────────────────────────────────────────────────────────

# Path to Google service account credentials JSON file
GOOGLE_CREDENTIALS_PATH=credentials.json

# ID from the Google Sheets URL:
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# Public link to the spreadsheet (sent to employees after approval)
SHEET_URL=https://docs.google.com/spreadsheets/d/your_spreadsheet_id_here/edit
