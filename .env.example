# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# Google Sheets API credentials
GOOGLE_CREDENTIALS_PATH=credentials.json
SPREADSHEET_ID=your_spreadsheet_id_here
SHEET_URL=https://docs.google.com/spreadsheets/d/your_spreadsheet_id_here/edit

# Admin Telegram IDs (comma-separated, no spaces)
# Superadmins: full access to all commands
SUPERADMIN_IDS=123456789,987654321

# Developer ID (for technical support and debugging)
DEVELOPER_ID=your_telegram_id_here
